{
  "name": "ecm-ai-backend",
  "version": "1.0.0",
  "description": "ECM AI Platform — Backend API Server",
  "main": "server.js",
  "scripts": {
    "start": "node backend/api-server.cjs",
    "start:worker": "node backend/queues/worker.cjs",
    "start:mcp": "node backend/mcp/server.cjs",
    "dev": "nodemon backend/api-server.cjs",
    "dev:worker": "nodemon backend/queues/worker.cjs",
    "migrate": "node src/database/migrate.js",
    "migrate:saas": "node backend/db/migrate-saas.cjs",
    "seed": "node src/database/seed.js",
    "test": "node --test 'tests/**/*.test.cjs' 'src/**/*.test.js'",
    "test:watch": "node --test --watch 'tests/**/*.test.cjs'",
    "lint": "eslint src/ backend/ --ignore-pattern node_modules --ignore-pattern frontend || true",
    "lint:fix": "eslint src/ backend/ --fix --ignore-pattern node_modules || true",
    "typecheck": "npx tsc --noEmit || true",
    "clean": "rm -rf dist build",
    "health": "curl -s http://localhost:4000/health",
    "deploy": "bash scripts/deploy.sh",
    "db:studio": "echo 'DB studio: psql $DATABASE_URL'",
    "providers:health": "curl -s http://localhost:4000/api/providers/health",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "uuid": "^10.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
