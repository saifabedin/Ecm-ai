# ─── DATABASE ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@pooler.neon.tech/dbname?sslmode=require
NEON_DATABASE_URL=postgresql://user:password@direct.neon.tech/dbname?sslmode=require

# ─── AUTH ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=30d

# ─── n8n ──────────────────────────────────────────────────────────────────────
N8N_WEBHOOK_BASE_URL=https://your-n8n-host/webhook
N8N_API_KEY=

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── WHATSAPP ─────────────────────────────────────────────────────────────────
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ─── GOOGLE ADS ───────────────────────────────────────────────────────────────
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=

# ─── META ADS ─────────────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# ─── PLATFORM ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://editorschoicemedia.in
API_URL=https://api.editorschoicemedia.in

# ─── MCP ──────────────────────────────────────────────────────────────────────
MCP_SERVER_URL=
MCP_API_KEY=

# ─── RATE LIMITING ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
