# ─── DATABASE ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ecm_ai?sslmode=require
NEON_DATABASE_URL=postgresql://user:password@direct.neon.tech/ecm_ai?sslmode=require

# ─── AUTHENTICATION ────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-very-long-random-string-minimum-64-characters
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=30d

# ─── REDIS & QUEUE ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
BULLMQ_QUEUE_PREFIX=ecm:

# ─── API ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:4000

# ─── LOGGING ───────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── RATE LIMITING ────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── n8n ───────────────────────────────────────────────────────────────
N8N_WEBHOOK_BASE_URL=https://your-n8n-host/webhook
N8N_API_KEY=

# ─── AWS ────────────────────────────────────────────────────────────────
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── WHATSAPP ──────────────────────────────────────────────────────────
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ─── GOOGLE ADS ─────────────────────────────────────────────────────────
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=

# ─── META ADS ──────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# ─── PLATFORM ──────────────────────────────────────────────────────────
FRONTEND_DOMAIN=https://editorschoicemedia.in
API_DOMAIN=https://api.editorschoicemedia.in

# ─── MCP ────────────────────────────────────────────────────────────
MCP_SERVER_URL=
MCP_API_KEY=
